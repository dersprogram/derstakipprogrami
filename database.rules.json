{
  "rules": {
    "plan-index": {
      ".read": true,
      ".write": "auth != null"
    },
    "yillik-planlar": {
      ".read": true,
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
